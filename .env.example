# =============================================================
# .env.example - Futbol Quant Bot
# Copiar como .env y completar con valores reales
# NUNCA subir .env al repo (ya esta en .gitignore)
# =============================================================

# -- The Odds API (OBLIGATORIO) --
# Obtener en: https://the-odds-api.com
ODDS_API_KEY=tu_api_key_aqui

# -- Telegram Bot (OBLIGATORIO para el bot) --
# Obtener hablando con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# -- Parametros del motor (OPCIONALES, tienen default) --
EDGE_MINIMO=3.0          # edge minimo para detectar value bet (%)
HORAS_DEFAULT=48         # ventana temporal default en horas
MAX_BETS_MSG=15          # maximo de bets a enviar por mensaje

# -- Melbet affiliate link (OPCIONAL) --
MELBET_LINK=https://refmelbet.com/L?tag=d_XXXXXX

# -- Google Sheets (OPCIONAL, para persistencia de bets) --
# GOOGLE_CREDENTIALS={"type":"service_account",...}
# GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
