# ══════════════════════════════════════════════
# Copiar este archivo como .env y completar los valores reales.
# El archivo .env NUNCA debe subirse a GitHub (ya está en .gitignore).

# ── OBLIGATORIO ──────────────────────────────
# Token del bot (obtenido de @BotFather en Telegram)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID del canal donde publicar picks (con el -100 al inicio)
# Para obtenerlo: reenviá un mensaje del canal a @userinfobot
CHANNEL_ID=-1001234567890

# Tu link de afiliado Melbet Argentina
MELBET_LINK=https://melbet.com.ar/es/?af=TUCODIGO

# ── OPCIONAL ─────────────────────────────────
# Tu Telegram ID personal (para comandos de admin)
ADMIN_ID=123456789

# ID del Google Spreadsheet con los picks
# IMPORTANTE: la hoja debe estar compartida como "Cualquiera con el link puede ver"
SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
